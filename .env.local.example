# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Dropbox OAuth
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret

# App URL (for OAuth callbacks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth.js (user accounts)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_GITHUB_ID=your_auth_github_client_id
AUTH_GITHUB_SECRET=your_auth_github_client_secret
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Vercel Postgres (user + API key storage)
POSTGRES_PRISMA_URL=your_pooled_postgres_url
POSTGRES_URL_NON_POOLING=your_direct_postgres_url

# Vercel KV (rate limiting)
KV_REST_API_URL=your_kv_rest_url
KV_REST_API_TOKEN=your_kv_rest_token
